########################################
#              Required                 #
########################################

# Steam account (downloads the game, authenticates the in-game lobby)
STEAM_USERNAME=""
STEAM_PASSWORD=""

# VNC password for the web admin interface
VNC_PASSWORD=""

########################################
#              Ports                   #
########################################
# Host-side mappings only; container ports are fixed. Change to avoid conflicts.

# GAME_PORT=24642        # UDP, multiplayer (Steam relay)
# QUERY_PORT=27015       # UDP, Steam query
# VNC_PORT=5800          # TCP, VNC web interface
# API_PORT=8080          # TCP, HTTP API
# STEAM_AUTH_PORT=3001   # internal only (steam-auth sidecar, no host mapping)

########################################
#           Performance                #
########################################

# Target ticks per second (default: 60, minimum: 10).
# Lower reduces CPU at the cost of choppier NPC movement. 20-30 suits production.
# SERVER_TPS=60

# Render rate: 0 = rendering disabled (default), N > 0 = draw at N fps for VNC.
# Runtime override: `rendering <fps>` console command or POST /rendering?fps=<int>.
# SERVER_FPS=0

########################################
#              Security                #
########################################

# Require players to authenticate with !login <password> (empty = disabled)
# SERVER_PASSWORD=""

# Failed login attempts before kick (default: 3)
# MAX_LOGIN_ATTEMPTS=3

# Seconds before unauthenticated players are kicked (default: 120, 0 = disabled)
# AUTH_TIMEOUT_SECONDS=120

# HTTP API for external tools (default: true)
# API_ENABLED=true

# API key protecting write endpoints (recommended in production)
# Generate: openssl rand -base64 32
# API_KEY=""

# Allow startup without VNC_PASSWORD or API_KEY (default: false)
# ALLOW_INSECURE_SETUP=false

########################################
#           Discord Bot                #
########################################

# Bot token from https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=""

# Bot nickname (default: farm name)
# DISCORD_BOT_NICKNAME=""

# Channel ID for two-way chat relay (requires Message Content Intent)
# DISCORD_CHAT_CHANNEL_ID=""

########################################
#              Advanced                #
########################################

# Docker image version: "latest", "preview", or a pin like "1.0.0"
# IMAGE_VERSION=latest

# Pre-existing Steam refresh token, instead of password (for CI/automation).
# Export after first login: docker compose run --rm steam-auth export-token
# STEAM_REFRESH_TOKEN=""

# Additional Steam accounts for E2E tests (JSON array). See .env.test.example.
# STEAM_ACCOUNTS='[{"user":"server","pass":"pw"},{"user":"client","pass":"pw"}]'

# Keep localized fonts for these languages so their text renders correctly
# (default: none — English-only, smallest download). Comma-separated codes:
# de-DE,es-ES,fr-FR,hu-HU,it-IT,ja-JP,ko-KR,pt-BR,ru-RU,tr-TR,zh-CN,th-TH
# STEAM_KEEP_LANGUAGES="pt-BR,ru-RU"

# Health check interval in seconds (default: 300)
# HEALTH_CHECK_SECONDS=300

# Performance optimizations that may break some mods (default: true)
# ENABLE_MOD_INCOMPATIBLE_OPTIMIZATIONS=true

# Force a new debug game on startup (default: false)
# FORCE_NEW_DEBUG_GAME=false

# Override verbose logging (default: config-file setting)
# VERBOSE_LOGGING=false

########################################
#       Development (build-time)       #
########################################
# Only needed to build the mod locally. Ignored by the Docker server.

# Path to your Stardew Valley install. Read by Directory.Build.props and the
# decompile scripts. Forward slashes work on both Windows and Linux.
#   Windows: "C:/Program Files (x86)/Steam/steamapps/common/Stardew Valley"
#   Linux:   "/home/user/.steam/steam/steamapps/common/Stardew Valley"
# GAME_PATH="C:/Program Files (x86)/Steam/steamapps/common/Stardew Valley"
