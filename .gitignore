# Misc
# Claude Code local machine state (absolute Windows paths, permission history, runtime lock)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.DS_Store
.fleet

# VS
.vs

# VSC
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/

# IntelliJ
.idea

# Resharper personal layer
JunimoMods.sln.DotSettings

# Logs
logs
*.log

# Local env files
.env
.env.*
!.env.example
!.env.test.example

# SSH private keys for remote Docker hosts (referenced by SDVD_DOCKER_HOSTS sshKey)
.sdvd_runner_key
.sdvd_runner_key.pub


# Local server settings
server-settings.json

# Build output
**/.output
**/bin
!docker/rootfs/opt/base/bin/
!docker/modern/rootfs/opt/bin/
**/obj
**/debug
**/decompiled
**/tmp

# Test artifacts (screenshots, etc.)
TestResults/

# diagnostics-command output (bind-mounted from the server container). Anchored to the compose
# working dirs — NOT a bare `diagnostics/`, which would also ignore the tool source in tools/.
/diagnostics/
/docker/modern/diagnostics/

# Dependency folders
node_modules/

# Test UI build output
tests/test-ui/dist/

# Decompiler version file
/version.txt

# Used by fetch-sdv-version.sh
/tools/depot-downloader/DepotDownloader.exe
/tools/depot-downloader/DepotDownloader.xml
/tools/.playground

# Extra mods
/mods
