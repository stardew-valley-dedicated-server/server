########################################
#       Test Environment Config        #
########################################
#
# Copy this file to .env.test and fill in values.
# The test system reads .env.test first, falling back to .env if not found.
#

# Steam accounts for test containers
# Without 2+ accounts, Steam/invite-code tests are skipped.
# Account 0 hosts the server, accounts 1+ are used by test clients.
# STEAM_ACCOUNTS='[
#   {"user":"server_account", "pass":"server_password"},
#   {"user":"client_account", "pass":"client_password"},
# ]'

# VNC password for test containers, leave empty to disable password (default: unset).
# VNC_PASSWORD=""

########################################
#         Test Runner Settings         #
########################################

# Docker hosts the runner places containers on (JSON array).
#
# Each entry:
#   id           required, unique. Used in network names and log fields.
#   serverSlots  required, positive integer.
#   clientSlots  required, positive integer.
#   endpoint     optional. Omit for the local default daemon (Unix socket /
#                named pipe). Remote: ssh://user@host. Requires OpenSSH on PATH.
#   sshKey       optional. Either a path to a private key (`~`-expanded or
#                relative to the project root), or inline key material — a
#                "-----BEGIN…" block, which the runner writes to a 0600 temp
#                file. Inline is for CI, where the whole SDVD_DOCKER_HOSTS JSON
#                (key included) is one secret. When set, the runner passes
#                `-i {key} -o IdentitiesOnly=yes` to every ssh invocation for
#                this host. Omit to fall back to ~/.ssh/config + ssh-agent.
#   socketPath   optional, remote hosts only. Daemon Unix socket on the remote
#                (default: /var/run/docker.sock). Override e.g.
#                ~/.docker/run/docker.sock for macOS Docker Desktop.
#
# Each test's server and clients run on the same host. Reuse-on-host
# scheduling: the runner picks a host first, then prefers a matching
# server already running on that host.
#
# Optional per-host fields:
#   gpu              set to true on hosts with an NVIDIA GPU + Container Toolkit
#                    installed. Containers placed on a gpu=true host get NVENC
#                    hardware video encoding; gpu=false (default) hosts use libx264.
#                    Mixed fleets are supported — each host is configured on its own.
#   concurrentStarts cap on simultaneous `docker create+start` calls against
#                    this daemon. When omitted, falls back to
#                    SDVD_MAX_CONCURRENT_STARTS (if set) and otherwise to this
#                    host's serverSlots+clientSlots — so a host sized for N
#                    containers can also start N concurrently. Independent
#                    across hosts; a beefy daemon and a laptop can carry
#                    different caps.
#   concurrentExtractions cap on simultaneous video-extraction operations
#                    (ffmpeg MKV→MP4 + Docker tar pull) against this daemon at
#                    run-end. Same fallback chain as concurrentStarts:
#                    SDVD_MAX_CONCURRENT_EXTRACTIONS, then serverSlots+clientSlots.
#                    Independent of concurrentStarts — different daemon code paths.
#
# Ensure the SDVD_DOCKER_HOSTS value uses single quotes (so $ inside the
# JSON isn't expanded by the shell).
#
# SDVD_DOCKER_HOSTS='[
#   {"id": "local", "serverSlots": 3, "clientSlots": 6, "gpu": true},
#   {"id": "vps",   "endpoint": "ssh://sdvd-runner@10.0.0.2", "sshKey": "~/.ssh/sdvd_runner",
#                   "serverSlots": 2, "clientSlots": 4},
#   {"id": "mac",   "endpoint": "ssh://julian@mac.lan",
#                   "serverSlots": 2, "clientSlots": 4}
# ]'

# Default cap on concurrent Docker container starts on a single daemon, used
# when a host's `concurrentStarts` JSON field is omitted. When this env var is
# also unset, each host defaults to its own serverSlots+clientSlots. Per-host
# `concurrentStarts` overrides both. Independent across hosts because separate
# daemons share no resources.
# SDVD_MAX_CONCURRENT_STARTS=3

# Default cap on concurrent video extractions on a single daemon at run-end,
# used when a host's `concurrentExtractions` JSON field is omitted. When this
# env var is also unset, each host defaults to its own serverSlots+clientSlots.
# Per-host `concurrentExtractions` overrides both. Independent of
# SDVD_MAX_CONCURRENT_STARTS — different daemon code paths (tar-stream I/O +
# in-container ffmpeg-concat CPU vs. docker create+start accept queue).
# SDVD_MAX_CONCURRENT_EXTRACTIONS=3

# Target ticks per second for test servers (default: 60, minimum: 1)
# SERVER_TPS=60

# Frames per second for test servers (default: 0, rendering disabled).
# Drives both the in-container draw cap AND the video recorder's sample rate.
# Set to 0 (or leave unset) to disable rendering and recording for servers.
# SERVER_FPS=0

# Target ticks per second for test clients (default: 60, minimum: 1)
# CLIENT_TPS=60

# Frames per second for test clients (default: 0, rendering disabled).
# Drives both the in-container draw cap AND the video recorder's sample rate.
# Set to 0 (or leave unset) to disable rendering and recording for clients.
# CLIENT_FPS=0

# Use local Stardew Valley process instead of containerized clients
# SDVD_HOST_CLIENT=true

# Test harness HTTP/wait tracing tier (default: none)
#  - none   -> cheapest. http_request emits method/path/status/duration only.
#              No body buffer, no respSummary, no X-Request-Id, no wait_started
#              events, no per-test http_wait mirror. CI / throughput-focused runs.
#  - basic  -> none + X-Request-Id on mutating verbs (POST/PUT/PATCH/DELETE) so
#              writes correlate with mod-side events. Reads stay header-free.
#  - full   -> every cross-process correlation: respBytes, X-Request-Id on
#              every verb, wait_started events, per-test http_wait mirror.
#              `make test-llm` overrides this to `full` automatically.
# Failure-path events (wait_failed, wait_cancelled, failure_context, recording_*)
# emit at every level — the failure runbook works at all tiers.
# SDVD_TEST_TRACING=none

# Per-container resource stats collection (default: docker+game)
#  - docker+game -> Docker stats stream + per-container HTTP /stats poll. Used
#                   by the Web UI's live FPS/TPS/memory graphs.
#  - docker      -> Docker stats stream only (CPU/memory still graphed).
#  - none        -> skip both. UI graphs render empty arrays gracefully.
# SDVD_TEST_STATS=docker+game

# Docker image tag (default: local)
# SDVD_IMAGE_TAG=local

# Skip Docker image builds and use existing images (default: false)
# SDVD_SKIP_BUILD=true

# Docker volume prefix for shared game-data/steam-session (default: server)
# SDVD_VOLUME_PREFIX=server

########################################
#           Video Recording            #
########################################

# Video recording mode (default: none)
#  - none       -> no recording
#  - failure    -> per-test clip extraction only for failing tests
#  - all        -> per-test clip for every test (defers extraction off the
#                  test critical path for passing tests)
# Note: In 'failure' and 'all' modes, per-container recordings are always made;
# the mode controls per-test clip extraction. Use 'none' to skip recording entirely.
# SDVD_TEST_RECORDING=none

# Record server containers (default: true)
# SDVD_TEST_RECORDING_SERVER=true

# Record client containers (default: true)
# SDVD_TEST_RECORDING_CLIENT=true

# Render resolution for test containers (default: 1280x720). Both the game window
# and the ffmpeg recording use these dimensions, so lowering them reduces rendering
# CPU, encoding cost, and clip size — and speeds up the suite. Use EVEN numbers
# (the encoder requires it; odd values are rounded down).
# DISPLAY_WIDTH=1280
# DISPLAY_HEIGHT=720

##################################
# GPU Acceleration (NVIDIA only) #
##################################

# GPU passthrough is configured per-host via the `gpu` field on each entry of
# SDVD_DOCKER_HOSTS (see Multi-Host Execution above). Requires NVIDIA GPU +
# NVIDIA Container Toolkit on the host that opts in. Containers on a GPU host
# use NVENC for ffmpeg video recording; containers on a CPU-only host use
# libx264. See https://developer.nvidia.com/video-encode-decode-support-matrix

################################################################################
# Multi-Host Execution                                                         #
#                                                                              #
# The runner is a single coordinator process that places test containers on    #
# one or more Docker hosts (`SDVD_DOCKER_HOSTS` above). All settings below     #
# are optional.                                                                #
################################################################################

# Stop on first failure (default: true).
# Due to server and client reuse, failures could end up in unexpected state,
# so we bail early to prevent cascading failures and unecessarily long runs.
# SDVD_STOP_ON_FAIL=true

# Disable parallel test execution (default: true). When 'false', tests run sequentially.
# SDVD_PARALLEL=true

# Screenshot capture mode for tests: 'all', 'done', or 'none' (default: 'done').
# 'done' captures only on test completion; 'all' captures on every step (high I/O).
# SDVD_TEST_SCREENSHOTS=done

# Max retry count for Docker image transfer to remote hosts (default: 1).
# SDVD_IMAGE_TRANSFER_RETRIES=1

# Max retry count for game-data volume transfer to remote hosts (default: 1).
# SDVD_GAME_DATA_TRANSFER_RETRIES=1

# Patience window (seconds) for a client lease when the pool is empty but
# under the container cap. If another test is using a client, wait up to this
# long for a return before building a fresh container (~60s on typical
# hardware). 0 disables the wait (eager creation). Default: 20.
# SDVD_CLIENT_LEASE_PATIENCE_S=20

# Video recording segment duration in seconds (default: 1).
# Smaller values give finer-grained per-test clip extraction at higher I/O cost.
# SDVD_TEST_RECORDING_SEGMENT_TIME=1

# Expose the test-client's OpenAPI explorer endpoints (/openapi.json, /openapi.yaml,
# /docs, /swagger) for manual HTTP-API debugging. Off by default. Read by the
# test-client mod process itself (JunimoTestClient ModEntry), so set it in the
# environment where you run the client by hand -- it is not plumbed through the
# E2E container, since automated tests never call these endpoints.
# SDVD_TEST_CLIENT_API_EXPLORER=0
