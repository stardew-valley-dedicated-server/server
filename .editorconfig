root = true

[*]
end_of_line = lf
indent_size = 4
indent_style = space
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.cs]
# CSharpier only rewrites whitespace and never inserts braces; IDE0011 closes that
# gap (build-time via EnforceCodeStyleInBuild in Directory.Build.props).
csharp_prefer_braces = true
dotnet_diagnostic.IDE0011.severity = error
csharp_style_namespace_declarations = file_scoped
dotnet_diagnostic.IDE0161.severity = error

# Reference-only third-party sources — don't flag their style in the IDE.
# Per-rule mutes: a category-level mute would lose to the per-rule severities above.
[{decompiled,sub_modules}/**.cs]
dotnet_diagnostic.IDE0011.severity = none
dotnet_diagnostic.IDE0161.severity = none
