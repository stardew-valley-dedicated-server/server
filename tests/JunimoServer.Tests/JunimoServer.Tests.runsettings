<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <ResultsDirectory>..\..\TestResults</ResultsDirectory>
    <EnvironmentVariables>
      <!-- Set to "true" to use a local Stardew Valley process instead of Docker containers (requires Steam) -->
      <!-- <SDVD_HOST_CLIENT>true</SDVD_HOST_CLIENT> -->
      <!-- Tracing tier: none (default), basic, full. See .env.test.example for details. -->
      <SDVD_TEST_TRACING>none</SDVD_TEST_TRACING>
      <!-- Per-container stats collection: docker+game (default), docker, none. -->
      <SDVD_TEST_STATS>docker+game</SDVD_TEST_STATS>
    </EnvironmentVariables>
  </RunConfiguration>
  <LoggerRunSettings>
    <Loggers>
      <Logger friendlyName="trx" enabled="True">
        <Configuration>
          <LogFileName>TestResults.trx</LogFileName>
        </Configuration>
      </Logger>
    </Loggers>
  </LoggerRunSettings>
  <!-- xUnit.net configuration -->
  <xUnit>
    <!-- Stop running further tests once a test has failed -->
    <StopOnFail>true</StopOnFail>
    <!-- Enable parallel execution at the collection level.
         Each collection has its own server container, so they can run concurrently.
         Concurrency is gated per-host by `serverSlots`/`clientSlots` in
         SDVD_DOCKER_HOSTS; xUnit's collection parallelism feeds that gate. -->
    <ParallelizeTestCollections>true</ParallelizeTestCollections>
    <ParallelizeAssembly>false</ParallelizeAssembly>
  </xUnit>
</RunSettings>
